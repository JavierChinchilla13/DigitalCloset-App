# Cloudinary Configuration
# Get these from your Cloudinary Dashboard (Settings > Enable unsigned uploading)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_here

# Background Removal Configuration
# Mode: browser | api | hybrid (default: hybrid)
VITE_BG_REMOVER_MODE=hybrid
# URL for the Python microservice
VITE_BG_REMOVER_API_URL=http://localhost:8000/remove-bg
